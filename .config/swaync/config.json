{
  : /etc/xdg/swaync/configSchema.json,
  positionX: right,
  positionY: top,
  layer: top,
  control-center-positionX: none,
  control-center-positionY: none,
  control-center-margin-top: 52,
  control-center-margin-bottom: 12,
  control-center-margin-left: 12,
  control-center-margin-right: 12,
  control-center-width: 400,
  control-center-height: 500,
  fit-to-screen: false,
  notification-window-width: 380,
  notification-grouping: true,
  notification-group-count: 3,
  notification-group-collapsed: true,
  keyboard-shortcuts: true,
  image-visibility: when-available,
  hide-body: ,
  hide-body-action: false,
  widgets: [title, dnd, mpris, volume, buttonsGrid, notifications],
  widget-config: {
    title: { text: Notifications, clear-all-button: true },
    dnd: { text: Do Not Disturb },
    mpris: { image-radius: 10 },
    volume: { label:  },
    buttonsGrid: {
      actions: [
        { label: , command: loginctl lock-session },
        { label: , command: firefox },
        { label: , command: ghostty },
        { label: , command: nautilus },
        { label: , command: code },
        { label: , command: flameshot gui }
      ]
    }
  }
}
