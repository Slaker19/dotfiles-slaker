{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
  "layer": "top",
  "control-center-positionX": "right",
  "control-center-positionY": "top",
  "control-center-margin-top": 4,
  "control-center-margin-bottom": 8,
  "control-center-margin-left": 8,
  "control-center-margin-right": 8,
  "control-center-width": 420,
  "control-center-height": 1060,
  "fit-to-screen": true,
  "notification-window-width": 380,
  "notification-grouping": true,
  "notification-group-count": 3,
  "notification-group-collapsed": true,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "hide-body": "",
  "hide-body-action": false,
  "widgets": ["title", "dnd", "notifications", "mpris", "volume", "backlight", "buttonsGrid"],
  "widget-config": {
    "title": { "text": "Notifications", "clear-all-button": true },
    "dnd": { "text": "Do Not Disturb" },
    "mpris": { "image-radius": 10 },
    "volume": { "label": "" },
    "backlight": { "label": "", "device": "intel_backlight", "subsystem": "backlight", "min": 5 },
    "buttonsGrid": {
      "actions": [
        { "label": "⏮", "command": "playerctl previous" },
        { "label": "▶", "command": "playerctl play-pause" },
        { "label": "⏭", "command": "playerctl next" },
        { "label": "", "command": "loginctl lock-session" },
        { "label": "", "command": "ghostty" },
        { "label": "", "command": "nautilus" },
        { "label": "", "command": "__BROWSER__" },
        { "label": "", "command": "grim -g \"$(slurp)\"" }
      ]
    }
  }
}
